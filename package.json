{
  "name": "form-dropoff-tracker",
  "type": "module",
  "version": "1.0.0",
  "description": "Form drop-off tracker dashboard — Astro + Webflow Cloud (D1)",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 migrations apply DB --local",
    "db:apply:remote": "wrangler d1 migrations apply DB --remote",
    "db:import": "wrangler d1 execute DB --remote --file=import.sql"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.0.0",
    "astro": "^5.0.0",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0"
  }
}
